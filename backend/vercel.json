{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "GOOGLE_MAPS_API_KEY": "@google_maps_api_key",
    "FIREBASE_PROJECT_ID": "@firebase_project_id",
    "NODE_ENV": "production"
  },
  "functions": {
    "src/server.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "regions": ["sin1"],
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
